PORT=3001

# Shared secret with Next.js web app
BOT_SERVICE_SECRET=your_shared_secret_here

# URL of your Next.js app (for triggering summarization)
WEB_APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# GCP Cloud Storage (optional - for transcript storage)
GCP_PROJECT_ID=your-gcp-project-id
GCP_BUCKET_NAME=meet-scribe-transcripts
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Firebase Admin (for updating meeting status)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Puppeteer (override for Docker/Railway)
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
